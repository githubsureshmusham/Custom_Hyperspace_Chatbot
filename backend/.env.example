# ===========================================
# LiteLLM Hyperspace Proxy Configuration
# ===========================================

# The base URL of your LiteLLM / Hyperspace proxy
# e.g. https://your-hyperspace-proxy.example.com  or  http://localhost:4000
LITELLM_PROXY_URL=https://api.hyperspace.example.com

# API key / virtual key issued by the LiteLLM proxy
LITELLM_API_KEY=sk-your-litellm-proxy-key

# Default model to use (must be a model configured in your proxy)
DEFAULT_MODEL=gpt-4o

# Comma-separated list of models to expose in the UI selector
AVAILABLE_MODELS=gpt-4o,gpt-4o-mini,claude-3-5-sonnet,gemini-1.5-pro

# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins ("*" for all)
CORS_ORIGINS=*

# Default system prompt
SYSTEM_PROMPT=You are a helpful, knowledgeable AI assistant. Answer clearly and concisely.